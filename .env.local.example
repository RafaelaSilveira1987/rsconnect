APP_NAME="RS Connect"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rs_connect
DB_USERNAME=root
DB_PASSWORD=

SESSION_NAME=rs_connect_session
SESSION_LIFETIME=120

EVOLUTION_DEFAULT_URL=http://localhost:8080
EVOLUTION_DEFAULT_API_KEY=
EVOLUTION_SSL_VERIFY=false
EVOLUTION_CA_BUNDLE=
EVOLUTION_WEBHOOK_TOKEN=token-local-rs-connect

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_AUTOREPLY_ENABLED=true
AI_HTTP_TIMEOUT=28
AI_MAX_OUTPUT_TOKENS=420
AI_MAX_REPLY_CHARS=1400
N8N_WEBHOOK_URL=

# Opcional: n8n para criar/sincronizar eventos em Google Calendar
N8N_CALENDAR_WEBHOOK_URL=

# ZIP 09: n8n por empresa deve ser configurado no painel Super Admin > Fluxos n8n.
# Esta variável continua apenas como fallback legado.
N8N_WEBHOOK_URL=

# Token opcional para validar callbacks do n8n em /webhooks/n8n/callback
N8N_CALLBACK_TOKEN=

# Pagamentos / Gateways
PAYMENT_HTTP_TIMEOUT=30

# Régua de cobrança / cron externo opcional
BILLING_CRON_TOKEN=
