APP_NAME="RS Connect"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo
# Gere com: php bin/generate-key.php
APP_KEY=base64:REPLACE_WITH_GENERATED_KEY

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rs_connect
DB_USERNAME=root
DB_PASSWORD=

SESSION_NAME=rs_connect_session
SESSION_LIFETIME=120

EVOLUTION_DEFAULT_URL=http://localhost:8080
EVOLUTION_DEFAULT_API_KEY=

# Em localhost, use false apenas se o PHP não reconhecer o certificado da Evolution.
EVOLUTION_SSL_VERIFY=false
EVOLUTION_CA_BUNDLE=
EVOLUTION_WEBHOOK_TOKEN=token-local-rs-connect
