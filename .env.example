APP_NAME="RS Connect"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo
# Gere com: php bin/generate-key.php
APP_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rs_connect
DB_USERNAME=root
DB_PASSWORD=

SESSION_NAME=rs_connect_session
SESSION_LIFETIME=120

EVOLUTION_DEFAULT_URL=http://localhost:8080
EVOLUTION_DEFAULT_API_KEY=

# SSL da Evolution API
EVOLUTION_SSL_VERIFY=true
EVOLUTION_CA_BUNDLE=

# Token usado para proteger o webhook de mensagens
EVOLUTION_WEBHOOK_TOKEN=troque-por-um-token-longo-e-aleatorio

# ZIP 05 — IA e automações
# Google Gemini API Key para resposta automática.
GEMINI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_AUTOREPLY_ENABLED=true
AI_HTTP_TIMEOUT=28
AI_MAX_OUTPUT_TOKENS=420
AI_MAX_REPLY_CHARS=1400

# Opcional: webhook global do n8n para receber eventos do RS Connect.
N8N_WEBHOOK_URL=
