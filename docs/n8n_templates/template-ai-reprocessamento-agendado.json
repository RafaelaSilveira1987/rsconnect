{
  "name": "RS Connect - Verificar fila da IA",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "id": "ScheduleAiQueue",
      "name": "A cada 5 minutos",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "url": "https://SEU_DOMINIO/webhooks/ai-reprocess/run",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-RS-AI-Reprocess-Token",
              "value": "COLE_AQUI_O_AI_REPROCESS_CRON_TOKEN"
            }
          ]
        },
        "options": {
          "timeout": 120000
        }
      },
      "id": "CallRsConnectAiQueue",
      "name": "Verificar fila no RS Connect",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [300, 0]
    }
  ],
  "connections": {
    "A cada 5 minutos": {
      "main": [
        [
          {
            "node": "Verificar fila no RS Connect",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
  "meta": {
    "templateCredsSetupCompleted": false,
    "instanceId": "rs-connect-ai-reprocess-template"
  }
}
