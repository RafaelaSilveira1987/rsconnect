      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst payload = body.payload || body;\nconst action = String(payload.action || 'create').toLowerCase();\nconst calendarId = String(payload.calendar_id || 'primary');\nconst safeId = String(payload.google_event_id || payload.google_event_id_hint || payload.idempotency_key || `rsconnect${payload.tenant_id}a${payload.appointment_id}`)\n  .toLowerCase().replace(/[^0-9a-v]/g, '').slice(0, 180);\nconst eventUrl = `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(calendarId)}/events/${encodeURIComponent(safeId)}`;\nconst eventsUrl = `https://www.googleapis.com/calendar/v3/calendars/${encodeURIComponent(calendarId)}/events`;\nconst callback = payload.callback || body.callback || {};\nconst descriptionParts = [];\nif (payload.customer?.name) descriptionParts.push(`Contato: ${payload.customer.name}`);\nif (payload.customer?.phone) descriptionParts.push(`WhatsApp: ${payload.customer.phone}`);\nif (payload.description) descriptionParts.push(String(payload.description));\ndescriptionParts.push(`RS Connect: ${payload.idempotency_key || safeId}`);\nconst eventBody = {\n  id: safeId,\n  summary: payload.title || 'Agendamento RS Connect',\n  description: descriptionParts.join('\\n'),\n  start: { dateTime: payload.start, timeZone: payload.timezone || 'America/Sao_Paulo' },\n  end: { dateTime: payload.end, timeZone: payload.timezone || 'America/Sao_Paulo' },\n  location: payload.meeting_url || payload.location || '',\n  extendedProperties: { private: {\n    rs_connect_key: String(payload.idempotency_key || safeId),\n    rs_connect_tenant_id: String(payload.tenant_id || ''),\n    rs_connect_appointment_id: String(payload.appointment_id || '')\n  }}\n};\nreturn [{json:{...payload, action, calendar_id:calendarId, google_event_id:safeId, event_url:eventUrl, events_url:eventsUrl, callback_url:callback.url, callback_token:callback.token, event_body:eventBody}}];"
